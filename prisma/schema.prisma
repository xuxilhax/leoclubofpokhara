// Leo Club of Pokhara — CMS Database Schema
// PostgreSQL-compatible schema (runs on SQLite for dev)
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// AUTH & USERS
// ============================================================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String
  role         UserRole @default(EDITOR)
  avatarUrl    String?
  isActive     Boolean  @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  auditLogs    AuditLog[]
  newsArticles NewsArticle[]
  applications MembershipApplication[] @relation("ReviewedBy")
}

enum UserRole {
  SUPER_ADMIN
  PRESIDENT
  VICE_PRESIDENT
  SECRETARY
  TREASURER
  EDITOR
}

// ============================================================
// EXECUTIVE BOARD
// ============================================================

model BoardMember {
  id          String   @id @default(cuid())
  name        String
  position    String
  bio         String
  photoUrl    String?
  email       String?
  phone       String?
  social      String? // JSON: { facebook, instagram, linkedin }
  order       Int      @default(0)
  isArchived  Boolean  @default(false)
  boardYear   String   @default("2025-2026")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================================
// MEMBERS DATABASE
// ============================================================

model Member {
  id             String         @id @default(cuid())
  memberId       String         @unique // e.g. LCP-2025-001
  name           String
  photoUrl       String?
  position       String?
  email          String         @unique
  phone          String?
  joinDate       DateTime
  status         MemberStatus   @default(ACTIVE)
  membershipType MembershipType @default(STANDARD)
  notes          String?
  address        String?
  dateOfBirth    DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
}

enum MemberStatus {
  ACTIVE
  INACTIVE
  ALUMNI
  RESIGNED
}

enum MembershipType {
  STANDARD
  LIFE
  HONORARY
  CHARTER
}

// ============================================================
// EVENTS
// ============================================================

model Event {
  id                String      @id @default(cuid())
  title             String
  description       String
  category          String      @default("General")
  startDate         DateTime
  endDate           DateTime?
  location          String
  coverImageUrl     String?
  registrationLimit Int         @default(0) // 0 = unlimited
  isPublished       Boolean     @default(true)
  isFeatured        Boolean     @default(false)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  registrations     EventRegistration[]
}

model EventRegistration {
  id        String   @id @default(cuid())
  eventId   String
  name      String
  email     String
  phone     String?
  createdAt DateTime @default(now())

  event     Event    @relation(fields: [eventId], references: [id], onDelete: Cascade)
}

// ============================================================
// PROJECTS
// ============================================================

model Project {
  id            String   @id @default(cuid())
  title         String
  description   String
  category      String   @default("Service") // Service, Fundraiser, Awareness
  coverImageUrl String?
  startDate     DateTime
  endDate       DateTime?
  location      String
  budget        Float    @default(0)
  volunteers    Int      @default(0)
  beneficiaries Int      @default(0)
  impact        String?
  isFeatured    Boolean  @default(false)
  isPublished   Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ============================================================
// NEWS & BLOG
// ============================================================

model NewsArticle {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  excerpt       String?
  content       String   @default("")
  coverImageUrl String?
  category      String   @default("General")
  tags          String   @default("") // comma-separated
  status        String   @default("DRAFT") // DRAFT, PUBLISHED, SCHEDULED
  publishedAt   DateTime?
  scheduledAt   DateTime?
  isFeatured    Boolean  @default(false)
  seoTitle      String?
  seoDescription String?
  authorId      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  author        User?    @relation(fields: [authorId], references: [id])
}

// ============================================================
// GALLERY
// ============================================================

model GalleryAlbum {
  id          String         @id @default(cuid())
  title       String
  description String?
  category    String         @default("Service")
  coverImage  String?
  order       Int            @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  images      GalleryImage[]
}

model GalleryImage {
  id        String   @id @default(cuid())
  albumId   String?
  title     String
  caption   String?
  url       String
  category  String   @default("Service")
  width     Int      @default(0)
  height    Int      @default(0)
  size      Int      @default(0)
  order     Int      @default(0)
  createdAt DateTime @default(now())

  album     GalleryAlbum? @relation(fields: [albumId], references: [id], onDelete: SetNull)
}

// ============================================================
// MEMBERSHIP APPLICATIONS
// ============================================================

model MembershipApplication {
  id           String           @id @default(cuid())
  name         String
  email        String
  phone        String?
  dateOfBirth  DateTime?
  address      String?
  occupation   String?
  motivation   String?
  status       ApplicationStatus @default(PENDING)
  reviewedBy   String?
  reviewedAt   DateTime?
  reviewNote   String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  reviewer     User?            @relation("ReviewedBy", fields: [reviewedBy], references: [id])
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
  WAITLISTED
}

// ============================================================
// TESTIMONIALS
// ============================================================

model Testimonial {
  id        String   @id @default(cuid())
  quote     String
  author    String
  role      String
  photoUrl  String?
  category  String   @default("Member") // Member, Community, Partner
  isApproved Boolean @default(false)
  isFeatured Boolean @default(false)
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// SPONSORS & PARTNERS
// ============================================================

model Sponsor {
  id          String   @id @default(cuid())
  name        String
  logoUrl     String?
  websiteUrl  String?
  category    String   @default("Partner") // Partner, Sponsor, Supporter
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================================
// DOWNLOADS
// ============================================================

model Download {
  id          String   @id @default(cuid())
  title       String
  description String?
  fileUrl     String
  fileType    String   @default("pdf")
  fileSize    Int      @default(0)
  category    String   @default("Document") // Document, Form, Report, Newsletter
  version     String   @default("1.0")
  downloadCount Int    @default(0)
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================================
// MEDIA LIBRARY
// ============================================================

model MediaAsset {
  id        String   @id @default(cuid())
  name      String
  url       String
  type      String   @default("image") // image, video, pdf, document
  mimeType  String?
  size      Int      @default(0)
  width     Int      @default(0)
  height    Int      @default(0)
  folder    String   @default("root")
  tags      String   @default("")
  createdAt DateTime @default(now())
}

// ============================================================
// CONTACT MESSAGES
// ============================================================

model ContactMessage {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  isRead    Boolean  @default(false)
  isReplied Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ============================================================
// SETTINGS
// ============================================================

model SiteSetting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

// ============================================================
// AUDIT LOGS
// ============================================================

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  userName  String
  action    String   // CREATE, UPDATE, DELETE, LOGIN, LOGOUT, PUBLISH
  module    String   // members, events, projects, etc.
  entityId  String?
  entityName String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

// ============================================================
// NOTIFICATIONS
// ============================================================

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String   @default("info") // info, success, warning, error
  module    String?
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())
}
